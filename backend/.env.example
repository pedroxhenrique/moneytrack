# ─── Servidor ───────────────────────────
PORT=3000
NODE_ENV=development

# ─── Banco LOCAL (SQLite) ────────────────
# Usado automaticamente em desenvolvimento
DB_PATH=./database/moneytrack.db

# ─── Banco PRODUÇÃO (MySQL - Railway) ────
# Não preencher localmente - Railway preenche automaticamente
# DATABASE_URL=mysql://user:password@host:port/database

# ─── JWT ─────────────────────────────────
JWT_SECRET=moneytrack_chave_secreta_trocar_em_producao
JWT_EXPIRES_IN=24h

# ─── CORS ────────────────────────────────
FRONTEND_URL=*
